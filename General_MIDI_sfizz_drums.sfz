// GM Drum Kit — sfizz variant
// Key-mapped drum samples (no program/channel filtering).
// Loaded by a SEPARATE sfizz instance in Birka for channel-10 notes.
// Uses ABSOLUTE paths (sfizz resets default_path per <group>).

<group>
ampeg_attack=0.001 ampeg_release=0.08

<region> sample=/Volumes/External/Code/VST2SFZ/General_MIDI_samples_drums/gm_drum_N35_v064.wav lokey=35 hikey=35 lovel=0 hivel=80
<region> sample=/Volumes/External/Code/VST2SFZ/General_MIDI_samples_drums/gm_drum_N35_v127.wav lokey=35 hikey=35 lovel=81 hivel=127
